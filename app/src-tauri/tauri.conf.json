{
    "build": {
        "beforeDevCommand": "bun vite",
        "beforeBuildCommand": "bun run build",
        "frontendDist": "../dist",
        "devUrl": "http://localhost:1420"
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
    },
    "productName": "weys",
    "version": "1.0.0",
    "identifier": "com.weys.app",
    "plugins": {},
    "app": {
        "withGlobalTauri": true,
        "security": {
            "csp": null
        },
        "windows": [
            {
                "title": "WeYS",
                "fullscreen": false,
                "resizable": true,
                "decorations": false,
                "width": 800,
                "height": 600,
                "transparent": true,
                "minWidth": 330,
                "minHeight": 430
            }
        ]
    }
}
